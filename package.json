{
  "name": "@oneciel-ai/ciel-runtime",
  "version": "0.1.1",
  "description": "Universal AI coding-agent runtime and model-routing layer for Claude, Codex, AGY, and compatible runtimes.",
  "license": "MIT",
  "author": "One Ciel LLC",
  "homepage": "https://github.com/OneCielAI/ciel-runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneCielAI/ciel-runtime.git"
  },
  "bugs": {
    "url": "https://github.com/OneCielAI/ciel-runtime/issues"
  },
  "type": "commonjs",
  "bin": {
    "ciel-runtime": "npm-bin/ciel-runtime.js",
    "cielrt": "npm-bin/ciel-runtime.js",
    "ciel-runtimectl": "npm-bin/ciel-runtimectl.js",
    "ciel-runtime-stop": "npm-bin/ciel-runtime-stop.js"
  },
  "files": [
    "ciel_runtime.py",
    "ciel_runtime_support/*.py",
    "ciel_runtime_support/providers/*.py",
    "ciel_runtime_support/protocols/*.py",
    "ciel-runtime",
    "ciel-runtime.cmd",
    "ciel-runtime.ps1",
    "ciel-runtime-menu.py",
    "ciel-runtime-tool-guard.py",
    "ciel-runtimectl",
    "ciel-runtimectl.cmd",
    "ciel-runtimectl.ps1",
    "ciel-runtime-stop",
    "ciel-runtime-stop.cmd",
    "ciel-runtime-stop.ps1",
    "npm-bin/",
    "install.sh",
    "install.ps1",
    "README.md",
    "LICENSE",
    "NOTICE",
    "docs/"
  ],
  "scripts": {
    "test": "python -m compileall -q ciel_runtime.py ciel_runtime_support ciel-runtime-menu.py ciel-runtime-tool-guard.py scripts && python -m unittest discover -s tests -p \"test_*.py\"",
    "test:unit": "python scripts/run_test_group.py unit",
    "test:router": "python scripts/run_test_group.py router",
    "test:channel": "python scripts/run_test_group.py channel",
    "test:runtime": "python scripts/run_test_group.py runtime",
    "check:docs": "python scripts/check_project_metadata.py",
    "lint": "python -m ruff check .",
    "demo:assets": "python scripts/make_demo_assets.py"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  }
}
