{
  "name": "@oneciel-ai/ciel-runtime",
  "version": "0.1.0",
  "description": "Universal AI coding-agent runtime and model-routing layer for Claude, Codex, AGY, and compatible runtimes.",
  "license": "MIT",
  "author": "One Ciel LLC",
  "homepage": "https://github.com/OneCielAI/ciel-runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneCielAI/ciel-runtime.git"
  },
  "bugs": {
    "url": "https://github.com/OneCielAI/ciel-runtime/issues"
  },
  "type": "commonjs",
  "bin": {
    "ciel-runtime": "npm-bin/claude-any.js",
    "cielrt": "npm-bin/claude-any.js",
    "claude-any": "npm-bin/claude-any.js",
    "claude-anyctl": "npm-bin/claude-anyctl.js",
    "claude-any-stop": "npm-bin/claude-any-stop.js"
  },
  "files": [
    "claude_any.py",
    "claude_any_support/*.py",
    "claude-any",
    "claude-any.cmd",
    "claude-any.ps1",
    "claude-any-menu.py",
    "claude-any-tool-guard.py",
    "claude-anyctl",
    "claude-anyctl.cmd",
    "claude-anyctl.ps1",
    "claude-any-stop",
    "claude-any-stop.cmd",
    "claude-any-stop.ps1",
    "npm-bin/",
    "install.sh",
    "install.ps1",
    "README.md",
    "LICENSE",
    "NOTICE",
    "docs/"
  ],
  "scripts": {
    "postinstall": "node npm-bin/postinstall.js",
    "test": "python -m py_compile claude_any.py claude_any_support/__init__.py claude_any_support/architecture.py claude_any_support/observability.py claude_any_support/transcript_filter.py claude-any-menu.py claude-any-tool-guard.py scripts/make_demo_assets.py && python -m unittest discover -s tests -p \"test_*.py\"",
    "lint": "python -m ruff check .",
    "demo:assets": "python scripts/make_demo_assets.py"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  }
}
